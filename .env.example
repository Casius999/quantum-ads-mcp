# Quantum ADS MCP — configuration (June 2026). PLACEHOLDERS ONLY — never commit real values.
# Copy to .env (gitignored). The new code loads via GoogleAdsClient.load_from_env().

GOOGLE_ADS_USE_PROTO_PLUS=True
GOOGLE_ADS_API_VERSION=v24

GOOGLE_ADS_DEVELOPER_TOKEN=INSERT_DEVELOPER_TOKEN
GOOGLE_ADS_CLIENT_ID=INSERT_CLIENT_ID.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=INSERT_CLIENT_SECRET
GOOGLE_ADS_REFRESH_TOKEN=INSERT_REFRESH_TOKEN

# Optional — manager (MCC) account, digits only
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Safety: read-only by default. Set to false only when mutations are intended (SP1+).
QUANTUM_ADS_READ_ONLY=true
